---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  image?: { src: string; alt: string };
}

const { title, description, pubDate, tags, slug, image } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const truncated = description.length > 120
  ? description.slice(0, 120) + '...'
  : description;
---

<article class="post-card">
  {image && (
    <a href={`/blog/${slug}`}>
      <img src={image.src} alt={image.alt} style="width:100%;height:200px;object-fit:cover;border-radius:6px;margin-bottom:1rem;" />
    </a>
  )}
  <h2><a href={`/blog/${slug}`}>{title}</a></h2>
  <p class="meta">
    <time datetime={pubDate.toISOString()}>{formattedDate}</time>
  </p>
  <p class="description">{truncated}</p>
  {tags.length > 0 && (
    <div class="tags">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  )}
</article>
