---
import Base from './Base.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  image?: { src: string; alt: string };
  canonicalURL?: string;
  headings: { depth: number; slug: string; text: string }[];
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
  rawContent?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author,
  tags,
  image,
  canonicalURL,
  headings,
  prevPost,
  nextPost,
  rawContent = '',
} = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Estimate reading time (avg 200 wpm)
const wordsPerMinute = 200;
const wordCount = rawContent ? rawContent.split(/\s+/).filter(Boolean).length : 0;
const readingTime = wordCount > 0 ? Math.ceil(wordCount / wordsPerMinute) : null;
---

<Base
  title={title}
  description={description}
  image={image?.src}
  canonicalURL={canonicalURL}
  pubDate={pubDate}
  updatedDate={updatedDate}
  type="article"
>
  <div class="back-link-wrap">
    <a href="/blog/" class="back-link">← Back to Blog</a>
  </div>

  <article>
    <h1>{title}</h1>
    <div class="post-meta">
      <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
      {updatedDate && (
        <span>Updated: <time datetime={updatedDate.toISOString()}>{formattedUpdatedDate}</time></span>
      )}
      <span>By {author}</span>
      {readingTime && <span class="reading-time">{readingTime} min read</span>}
    </div>
    {tags.length > 0 && (
      <div class="tags" style="margin-bottom: 2rem;">
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    )}
    <TableOfContents headings={headings} />
    <div class="content">
      <slot />
    </div>
  </article>

  {(prevPost || nextPost) && (
    <nav class="post-nav">
      <div class="post-nav-inner">
        {prevPost ? (
          <a href={`/blog/blog/${prevPost.slug}/`} class="post-nav-link post-nav-prev">
            <span class="post-nav-label">← Previous</span>
            <span class="post-nav-title">{prevPost.title}</span>
          </a>
        ) : <span />}
        {nextPost ? (
          <a href={`/blog/blog/${nextPost.slug}/`} class="post-nav-link post-nav-next">
            <span class="post-nav-label">Next →</span>
            <span class="post-nav-title">{nextPost.title}</span>
          </a>
        ) : <span />}
      </div>
    </nav>
  )}
</Base>

<style>
  .back-link-wrap {
    margin-bottom: 1.5rem;
  }
  .back-link {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s;
  }
  .back-link:hover {
    color: var(--primary);
    text-decoration: none;
  }

  .post-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .post-nav-inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    max-width: 45%;
    color: var(--text-light);
    text-decoration: none;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: border-color 0.2s;
  }
  .post-nav-link:hover {
    border-color: var(--primary);
    text-decoration: none;
  }
  .post-nav-next {
    text-align: right;
    margin-left: auto;
  }
  .post-nav-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    font-weight: 600;
  }
  .post-nav-title {
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.3;
  }

  @media (max-width: 640px) {
    .post-nav-inner {
      flex-direction: column;
    }
    .post-nav-link {
      max-width: 100%;
    }
    .post-nav-next {
      text-align: left;
    }
  }
</style>
